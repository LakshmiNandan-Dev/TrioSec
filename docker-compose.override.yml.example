# Optional local overrides. Copy to docker-compose.override.yml (git-ignored).
# Adds Mailpit, a fake SMTP server with a web inbox, for testing report emails
# without a real mail account.
#
# In TrioSec Settings use:  host=mailpit  port=1025  TLS=off
# Then read the mail at http://localhost:8025
services:
  mailpit:
    image: axllent/mailpit:latest
    ports:
      - "8025:8025"
