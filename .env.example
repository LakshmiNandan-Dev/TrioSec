# --- Postgres ---
POSTGRES_USER=triosec
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=triosec

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Initial admin credentials (seeded on first boot only)
ADMIN_EMAIL=admin@triosec.local
ADMIN_PASSWORD=change-me-admin-password

# --- Secrets encryption (SMTP password at rest) ---
# Any long random string works; it is hashed into a Fernet key.
# Generate with: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=

# --- Workspace ---
# Absolute host path that contains the codebases you want to scan.
# It is mounted read-only into TrioSec at /workspace.
WORKSPACE_ROOT=/absolute/path/to/your/code

# --- ZAP (DAST) ---
# Generate with: openssl rand -hex 16
ZAP_API_KEY=
# Cap the ZAP spider so large/JS-heavy sites can't crawl forever. When the cap is
# reached the scan proceeds with whatever was crawled instead of failing.
ZAP_SPIDER_MAX_DURATION_MIN=5
ZAP_SPIDER_MAX_DEPTH=5

# --- UI ---
TRIOSEC_PORT=8080
